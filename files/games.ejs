<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ethereal | Home</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap');

        :root {
            --bg-color: #050505;
        }

        * {
            font-family: 'Montserrat', sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: #FFF;
        }

        .nav-bar {
            display: flex;
            justify-content: center;
            align-items: center;
            position: fixed;
            top: -5px;
            left: 0;
            right: 0;
            width: 100%;
            background-color: #050505b8;
        }

        .nav-left {
            margin-left: 25px;
            margin-right: auto;
        }

        .nav-right {
            margin-left: auto;
            margin-right: 25px;
        }

        .nav-bar button {
            background-color: transparent;
            border: 2px solid #1c1c1c;
            color: #FFF;
            padding: 10px;
            border-radius: 5px;
            margin: 2.5px;
            transition: 0.25s ease;
        }

        .nav-bar button:hover {
            transform: scale(1.1);
            background-color: #1c1c1c;
            cursor: pointer;
        }

        .nav-bar button:active {
            background-color: #FFF;
            border: 2px solid #FFF;
            color: #000;
        }

        .input-container {
            display: flex;
            align-items: center;
            justify-content: center;
            margin-top: 20px;
            width: 100%;
        }

        .input-container input {
            padding: 10px;
            border: 2px solid #1c1c1c;
            border-radius: 5px 0 0 5px;
            background-color: #101010;
            color: #FFF;
            outline: none;
            flex: 1;
            max-width: 300px;
        }

        .input-container button {
            padding: 10px;
            border: 2px solid #1c1c1c;
            border-left: none;
            border-radius: 0 5px 5px 0;
            background-color: #1c1c1c;
            color: #FFF;
            cursor: pointer;
            transition: 0.25s ease;
        }

        .input-container button:hover {
            background-color: #FFF;
            color: #000;
            border: 2px solid #FFF;
        }

        .input-container button:active {
            background-color: #050505;
            color: #FFF;
            border: 2px solid #FFF;
        }

        .games {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            margin-top: 20px;
        }

        .game-card {
            background-color: #101010;
            border-radius: 10px;
            margin: 10px;
            padding: 15px;
            width: 200px;
            text-align: center;
            transition: transform 0.25s ease, box-shadow 0.25s ease;
            cursor: pointer;
        }

        .game-card img {
            border-radius: 10px;
            width: 100%;
        }

        .game-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.5);
        }

        ::-webkit-scrollbar {
            width: 0.4rem;
            height: 0.5rem;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
            width: 0.4rem;
            height: 0.5rem;
        }

        ::-webkit-scrollbar-thumb {
            background: #101010;
            border-radius: 5px;
            width: 0.4rem;
            height: 0.5rem;
        }
    </style>
</head>

<body>
    <div id="load-div">
        <center>
            <div class="nav-bar">
                <div class="nav-left">
                    <h1><i>Ethereal</i></h1>
                </div>
                <div class="nav-right">
                    <button>Home</button>
                    <button>Games</button>
                    <button>Apps</button>
                    <button>Settings</button>
                </div>
            </div>
        </center>
        <center>
            <div class="games" id="games"></div>
        </center>
    </div>
    <script src="/games.js"></script>
</body>

</html>
