<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Textbook</title>
    <style>
        iframe {
            position: fixed;
            top: 0;
            bottom: 0;
            left: 0;
            right: 0;
            width: 100%;
            height: 100%;
        }
        .navigation-bar {
            display: flex;
            justify-content: center;
            align-items: center;
            background-color: #050505;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            width: 100%;
            z-index: 999;
        }

        .navigation-bar .align-right {
            margin-right: 25px;
            margin-left: auto;
        }

        .navigation-bar .align-left {
            margin-left: 25px;
            margin-right: auto;
        }

        .navigation-bar button {
            padding: 10px;
            background-color: #101010;
            color: #FFF;
            border: 2px solid #fff;
            border: 5px;
            margin: 5px;
            border-radius: 5px;
            width: 2.5em;
        }
    </style>
    <script src="https://kit.fontawesome.com/0e8a84fff9.js" crossorigin="anonymous"></script></head>
<body>
    <div class="navigation-bar">
        <div class="align-left">
            <button>
                <i class="fa-solid fa-arrow-left"></i>
            </button>
            <button>
                <i class="fa-solid fa-rotate"></i>
            </button>
            <button>
                <i class="fa-solid fa-arrow-right"></i>
            </button>
        </div>
        <div class="align-right">

        </div>
    </div>
    <iframe src="" frameborder="0">

    </iframe>
</body>
</html>