<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Textbook</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap');

        :root {
            --bg-color: #050505;
        }

        * {
            font-family: 'Montserrat', sans-serif;
        }

        a {
            color: #FFF;
            text-decoration: none;
            transition: 0.25s;
        }

        a:hover {
            color: #858585;
        }

        iframe {
            position: fixed;
            top: 0;
            bottom: 0;
            left: 0;
            right: 0;
            width: 100%;
            height: 100%;
        }

        .navigation-bar {
            display: flex;
            justify-content: center;
            align-items: center;
            background-color: #050505;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            width: 100%;
            z-index: 999;
            padding: 10px;
        }

        .navigation-bar .align-right {
            margin-right: 25px;
            margin-left: auto;
            align-items: center;
            display: flex;
            justify-content: center;
        }

        .navigation-bar .align-left {
            display: flex;
            justify-content: center;
            margin-left: 10px;
            margin-right: auto;
            align-items: center;
        }

        .navigation-bar button {
            background-color: #101010;
            height: 100%;
            border: 2px solid #202020;
            width: 2.5em;
            padding: 7px;
            border-radius: 1000px;
            margin-left: 5px;
            margin-right: 5px;
            transition: 0.25s ease;
            color: #FFF;
        }

        .navigation-bar button:hover {
            transform: scale(1.1);
            background-color: #FFF;
            border: 2px solid #FFF;
            color: #000;
            cursor: pointer;
        }

        .navigation-bar button:active {
            background-color: transparent;
            border: 2px solid #202020;
            color: #FFF;
        }

        .navigation-bar input {
            padding: 5px;
            border: 2px solid #1c1c1c;
            border-radius: 5px;
            background-color: #101010;
            color: #FFF;
            outline: none;
            flex: 1;
            width: 15em;
            text-align: center;
            margin-right: 15px;
        }

        .navigation-bar img {
            width: 2em;
            margin-right: 10px;
        }
    </style>
    <script src="https://kit.fontawesome.com/0e8a84fff9.js" crossorigin="anonymous"></script>

    <script src="/baremux/index.js" defer></script>
    <script src="/epoxy/index.js" defer></script>
    <script src="/uv.bundle.js" defer></script>
    <script src="/uv.config.js" defer></script>
    <script src="./js/proxy-registeration/register-sw.js" defer></script>
    <script src="./js/proxy-registeration/search.js" defer></script>
    <script type="application/javascript" src="./js/proxy-registeration/proxy-backend.js" defer></script>
</head>

<body>
    <div class="navigation-bar">
        <div class="align-left">
            <img src="https://www.google.com/s2/favicons?domain=https://example.com&sz=${size}" id="faviconProxy">
            <a href="https://example.com" target="_blank" id="proxyLink">Loading...</a>
        </div>
        <div class="align-right">
            <form id="proxy_uv_form">
                <input type="text" placeholder="Search or type a URL..." id="proxy_uv_input">
            </form>
            <button onclick="location.replace('/')"><i class="fa-solid fa-home"></i></button>
            <button><i class="fa-solid fa-up-right-from-square"></i></button>
            <button><i class="fa-solid fa-code"></i></button>
            <button><i class="fa-solid fa-angle-left"></i></button>
            <button><i class="fa-solid fa-rotate"></i></button>
            <button><i class="fa-solid fa-angle-right"></i></button>
        </div>
    </div>
    <iframe src="" frameborder="0" id="res">

    </iframe>
    <script>
        function calculateNavBar() {
            setTimeout(() => {
                var navbarHeight = document.querySelector('.navigation-bar').offsetHeight;
                document.querySelector('iframe').style.paddingTop = navbarHeight + 'px';
                document.querySelector('iframe').style.height = `calc(100% - ${navbarHeight}px)`;
                calculateNavBar();
            }, 50);
        }
        calculateNavBar();
    </script>

    <script>

        /*
